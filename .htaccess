Options -Indexes

# Proteger arquivos sensíveis
<FilesMatch "(config\.php|\.env|\.gitignore|schema\.sql|\.installed)$">
    Order allow,deny
    Deny from all
</FilesMatch>

RewriteEngine On

# Bloquear acesso direto à pasta /public/ (requisições externas apenas)
RewriteRule ^public(/.*)?$ - [F,L]

# Servir assets estáticos diretamente de public/assets/ (sem expor o caminho)
RewriteRule ^assets/(.+)$ public/assets/$1 [L]

# Rota raiz: /portal/ é um diretório real, !-d bloquearia a reescrita.
# Regra explícita sem condição de arquivo/diretório para o caminho vazio.
RewriteRule ^$ public/index.php [QSA,END]

# Tudo o mais vai para public/index.php (rewrite interno).
# Usa [END] para evitar iteração dupla das regras (Apache/LiteSpeed).
# public/index.php detecta ausência de config.php e redireciona para /install/.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/index.php [QSA,END]
